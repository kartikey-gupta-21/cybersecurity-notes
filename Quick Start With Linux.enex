    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div style="display:none;--en-chs:&quot;&quot;"> </div><div><br/></div><div><b>LESSON 1 : First Linux Lab                                                                    LESSON 2 : BASIC FILE OPERATIONS</b></div><table width="881.2002105712891px" style="border-collapse:collapse;width:881.2002105712891px;"><colgroup><col style="width: 118.39997863769531px;" /><col style="width: 296px;" /><col style="width: 46px;" /><col style="width: 139.20001220703125px;" /><col style="width: 281.6002197265625px;" /></colgroup><tbody><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div style="text-align:center;"><b><u>COMMANDS</u></b></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div style="text-align:center;"><b><u>USE</u></b></div></td><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div style="text-align:center;"><b><u>COMMANDS</u></b></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div style="text-align:center;"><b><u>USE</u></b></div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>echo " "</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>To print</div></td><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>pwd</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>prints current working directory</div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>whoami</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>Displaying the Current User</div></td><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>echo ~</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(63, 74, 84);">display the path to your home directory</span></div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>id</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>to display user and group information</div></td><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>ls</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>lists all <span style="color:rgb(63, 74, 84);">files and directories</span> in your current directory</div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>id root </div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>to look up for other users
"root" is the superuesr</div></td><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>ls ~</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>lists all <span style="color:rgb(63, 74, 84);">files and directories</span> in your home directory</div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>id -un</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>prints only your username</div></td><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>ls -l</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>"long" format listing (i.e. additional details like file permissions, owner, size, and modification date)</div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;" colspan="2" rowspan="12"><div><br/></div></td><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>ls -a</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>will show all files, including the hidden</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>ls -la</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>combines the long format (-l) with showing all files (-a)</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>cd ..</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>move one level to parent directory</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>cd project</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>return to project directory</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>cd ~</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>move to home directory</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>cd &lt;address></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>to move to the address directory</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>touch file1.txt</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>touch command is used to create an empty file. If the file already exists, it updates the file's timestamp without changing its content</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>echo "hello" > file2.txt</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>> symbol redirects the output of echo into a file named file2.txt. If the file doesn't exist, it's created. If it does exist, its content is replaced
Whereas if you use >> the content gets appended</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>echo "Hidden file" > .hiddenfile</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>creates a hidden file</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>mkdir testdir</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>create a directory testdir</div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>ls -l testdir</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(63, 74, 84);">lists the contents of the </span><code>testdir</code><span style="color:rgb(63, 74, 84);"> directory</span></div></td></tr><tr><td style="background-color:#ffc200;color:#333;border-color:hsl(45.60000000000002, 100%, 40%);border-width:1px;border-style:solid;padding:10px;"><div><span style="color:rgb(229, 158, 37);--inversion-type-color:simple;"><span style="--en-markholder:true;"><br/></span></span></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>cp file1.txt file1_copy.txt</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>creates a copy of file1.txt named file1_copy.txt in the current directory.</div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>cp file2.txt TestDir</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>copies file2 to TestDir</div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>cp -r TestDir TestDirCopy</div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div>-r option stands for "recursive". It's necessary when copying directories to ensure all contents are copied</div><div>TestDir copied to TestDirCopy entire</div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td></tr><tr><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td><td style="border-color:#ccc;border-width:1px;border-style:solid;padding:10px;"><div><br/></div></td></tr></tbody></table><div><br/></div><div><b><span style="--en-markholder:true;"><br/></span></b></div><div><b><span style="--en-markholder:true;"><br/></span></b></div><div><br/></div></en-note>      ]]>
